# Supabase — public keys (safe to commit, never the service role key)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Seed script only — NEVER commit actual values, NEVER use in the app
# Add .env to .gitignore and populate locally before running: npx ts-node scripts/seed.ts
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
